{
	"compilerOptions": {
		"preserveSymlinks": true,
		"skipLibCheck": true,
		"module": "CommonJS",
		"moduleResolution": "Bundler",
		"target": "ES2023",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"rootDir": "src",
		"outDir": "out",
		"declaration": true,
		"composite": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"noImplicitOverride": true,
		"types": ["node"]
	},
	"exclude": [
		"node_modules",
		"tests",
		"out",
		"*.cjs",
	]
}